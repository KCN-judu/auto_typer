{
  "name": "auto-typer-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "desktop:dev": "npm run dev --workspace @auto-typer/desktop",
    "desktop:build": "npm run build --workspace @auto-typer/desktop",
    "desktop:typecheck": "npm run typecheck --workspace @auto-typer/desktop",
    "desktop:test": "npm run prepare:electron --workspace @auto-typer/desktop && tsc -p apps/desktop/tsconfig.test.json && node apps/desktop/electron/device-link.test.mjs && node apps/desktop/electron/group-execution-watchdog.test.mjs && rm -rf apps/desktop/dist-test",
    "tcp:probe": "node apps/desktop/electron/tcp-probe.mjs",
    "firmware:test": "node src/auto_typer/test/run-tests.mjs",
    "firmware:compile": "node tools/auto-typer-arduino.mjs compile-source",
    "firmware:package": "node tools/auto-typer-arduino.mjs package",
    "firmware:package:verify": "node tools/auto-typer-arduino.mjs verify-package",
    "firmware:package:upload": "node tools/auto-typer-arduino.mjs upload-package",
    "firmware:workspace": "node tools/auto-typer-workspace.mjs package",
    "firmware:workspace:verify": "node tools/auto-typer-workspace.mjs verify"
  }
}
